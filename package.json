{
  "name": "coding-camp-2025",
  "version": "1.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:staging": "ng build --configuration staging",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "npm run lint:fix && npm run lint:format",
    "lint:fix": "ng lint --fix",
    "lint:format": "prettier --write \"src/**/*.{ts,css,scss,html}\" --log-level warn",
    "lint:ci": "ng lint --format json --output-file eslint-report.json",
    "generate-icons": "node src/scripts/generate-maskable-icons.js"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.2",
    "@angular/cdk": "^22.0.2",
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/material": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/platform-browser-dynamic": "^22.0.2",
    "@angular/router": "^22.0.2",
    "@angular/service-worker": "^22.0.2",
    "@auth0/angular-jwt": "^5.2.0",
    "@ng-icons/core": "^33.3.0",
    "@ng-icons/heroicons": "^33.3.0",
    "@ngx-translate/core": "^18.0.0",
    "@ngx-translate/http-loader": "^18.0.0",
    "@swimlane/ngx-datatable": "^24.0.0",
    "@types/leaflet": "^1.9.21",
    "browser-image-compression": "^2.0.2",
    "dompurify": "^3.4.11",
    "leaflet": "^1.9.4",
    "ngx-cookie-service": "^22.0.0",
    "ngx-quill": "^31.0.1",
    "quill": "^2.0.3",
    "rxjs": "~7.8.2",
    "sharp": "^0.35.2",
    "surrealdb": "^2.0.3",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.2",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/jasmine": "^6.0.0",
    "angular-eslint": "^22.0.0",
    "autoprefixer": "^10.5.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
